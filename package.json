{
  "name": "biblioteca-de-clemens",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "valaxy build --ssg",
    "build:spa": "valaxy build",
    "build:ssg": "valaxy build --ssg",
    "dev": "valaxy --port 4859",
    "officium1962:export": "node scripts/officium1962/run-do-export.mjs",
    "officium1962:build-day": "node scripts/officium1962/build-day.mjs",
    "officium1962:compare": "node scripts/officium1962/compare-with-upstream.mjs",
    "officium1962:preview": "vite --config playground/officium1962/vite.config.mjs",
    "officium1962:validate": "vitest run features/officium1962 && node scripts/officium1962/compare-with-upstream.mjs",
    "rss": "valaxy rss",
    "serve": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "valaxy": "0.28.11",
    "valaxy-theme-yun": "0.28.11"
  },
  "devDependencies": {
    "@iconify-json/ri": "^1.2.10",
    "opencc-js": "^1.4.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
