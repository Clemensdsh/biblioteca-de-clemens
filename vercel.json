{
  "cleanUrls": true,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/data/officium1962/manifest.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/data/officium1962/(shared/manifest.json|years/.*/(manifest|calendar).json)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }]
    },
    {
      "source": "/data/officium1962/(shared/blocks-.*.json|years/.*/days/.*.json)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }]
    }
  ]
}
